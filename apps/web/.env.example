# ===========================================
# TradePath Web - Environment Variables
# ===========================================

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

# Auth.js Configuration
AUTH_SECRET=your-auth-secret-key-at-least-32-characters-long
AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# API URL for server-side requests (only used in production)
# Development uses Next.js proxy rewrites
NEXT_PUBLIC_API_URL=http://localhost:4000

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe publishable key (public)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Google reCAPTCHA v3 (for bot protection)
# Get keys from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
