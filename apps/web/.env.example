# ===========================================
# TradePath Web - Environment Variables
# ===========================================

# API URL for server-side requests
# Development: http://localhost:4000
# Production: Your API server URL (e.g., https://api.tradepath.io)
NEXT_PUBLIC_API_URL=http://localhost:4000

# App URL (for OAuth redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe publishable key (public)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Google OAuth (for client-side)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
