  // Logo data stored as JSON: { "BTC": { "logoUrl": "...", "color": "#F7931A" }, ... }
  cryptoLogos  Json     @default("{}") @map("crypto_logos")   // Crypto assets
  stockLogos   Json     @default("{}") @map("stock_logos")    // Stocks & ETFs
