// ===========================================
// TradePath Database Schema
// ===========================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ===========================================
// User & Authentication
// ===========================================

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  passwordHash  String?  @map("password_hash") @db.VarChar(255)
  name          String   @db.VarChar(100)
  avatarUrl     String?  @map("avatar_url")
  googleId      String?  @unique @map("google_id") @db.VarChar(255)

  // Gamification
  level         Int      @default(1)
  xp            Int      @default(0)
  streakDays    Int      @default(0) @map("streak_days")
  streakLastDate DateTime? @map("streak_last_date") @db.Date

  // Settings
  preferredCoins String[] @default(["BTC", "ETH", "SOL"]) @map("preferred_coins")
  notificationSettings Json @default("{}") @map("notification_settings")
  reportValidityPeriods Int @default(50) @map("report_validity_periods") // Number of periods before report expires

  // Referral
  referralCode  String?  @unique @map("referral_code") @db.VarChar(20)
  referredById  String?  @map("referred_by_id") @db.Uuid
  referredBy    User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("UserReferrals")

  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  // Relations
  creditBalance    CreditBalance?
  creditTransactions CreditTransaction[]
  analyses         Analysis[]
  priceAlerts      PriceAlert[]
  dailyRewards     DailyReward[]
  achievements     UserAchievement[]
  referralsMade    Referral[] @relation("ReferrerReferrals")
  referralReceived Referral?  @relation("ReferredReferrals")
  quizAnswers      QuizAnswer[]
  reports          Report[]

  @@map("users")
}

// ===========================================
// Credits System
// ===========================================

model CreditBalance {
  userId           String   @id @map("user_id") @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance          Int      @default(25)
  dailyFreeRemaining Int    @default(5) @map("daily_free_remaining")
  dailyResetAt     DateTime @default(now()) @map("daily_reset_at")

  lifetimeEarned   Int      @default(25) @map("lifetime_earned")
  lifetimeSpent    Int      @default(0) @map("lifetime_spent")
  lifetimePurchased Int     @default(0) @map("lifetime_purchased")

  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("credit_balances")
}

model CreditTransaction {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount       Int      // positive = credit, negative = debit
  balanceAfter Int      @map("balance_after")

  type         TransactionType
  source       String   @db.VarChar(100) // 'daily_login', 'spin', 'quiz', 'analysis_step_2', etc.

  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("credit_transactions")
}

enum TransactionType {
  PURCHASE
  REWARD
  SPEND
  REFUND
  REFERRAL
  BONUS
}

model CreditPackage {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(50)
  credits         Int
  bonusCredits    Int      @default(0) @map("bonus_credits")
  priceUsd        Decimal  @map("price_usd") @db.Decimal(10, 2)
  pricePerCredit  Decimal  @map("price_per_credit") @db.Decimal(10, 4)
  discountPercent Int      @default(0) @map("discount_percent")
  isPopular       Boolean  @default(false) @map("is_popular")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("credit_packages")
}

// ===========================================
// Achievements & Rewards
// ===========================================

model Achievement {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @unique @db.VarChar(50)
  name            String   @db.VarChar(100)
  description     String?
  category        AchievementCategory
  icon            String?  @db.VarChar(50)

  xpReward        Int      @default(0) @map("xp_reward")
  creditReward    Int      @default(0) @map("credit_reward")

  requirementType RequirementType @map("requirement_type")
  requirementValue Int     @map("requirement_value")
  requirementMetadata Json @default("{}") @map("requirement_metadata")

  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  users           UserAchievement[]

  @@map("achievements")
}

enum AchievementCategory {
  ANALYSIS
  WHALE
  TRADING
  SOCIAL
  EDUCATION
  STREAK
}

enum RequirementType {
  COUNT
  STREAK
  PERCENTAGE
  SINGLE
}

model UserAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String   @map("achievement_id") @db.Uuid
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  progress      Int      @default(0)
  isUnlocked    Boolean  @default(false) @map("is_unlocked")
  unlockedAt    DateTime? @map("unlocked_at")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model DailyReward {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardDate   DateTime @map("reward_date") @db.Date

  loginClaimed Boolean  @default(false) @map("login_claimed")
  loginCredits Int      @default(0) @map("login_credits")

  spinUsed     Boolean  @default(false) @map("spin_used")
  spinResult   Int      @default(0) @map("spin_result")

  quizCompleted Boolean @default(false) @map("quiz_completed")
  quizCorrect  Boolean  @default(false) @map("quiz_correct")
  quizCredits  Int      @default(0) @map("quiz_credits")

  adsWatched   Int      @default(0) @map("ads_watched")
  adsCredits   Int      @default(0) @map("ads_credits")

  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([userId, rewardDate])
  @@index([userId, rewardDate])
  @@map("daily_rewards")
}

// ===========================================
// Referrals
// ===========================================

model Referral {
  id              String   @id @default(uuid()) @db.Uuid
  referrerId      String   @map("referrer_id") @db.Uuid
  referrer        User     @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredId      String   @unique @map("referred_id") @db.Uuid
  referred        User     @relation("ReferredReferrals", fields: [referredId], references: [id])

  status          ReferralStatus @default(PENDING)

  referrerCreditsEarned Int @default(0) @map("referrer_credits_earned")
  referredCreditsEarned Int @default(0) @map("referred_credits_earned")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([referrerId])
  @@map("referrals")
}

enum ReferralStatus {
  PENDING
  REGISTERED
  FIRST_ANALYSIS
  FIRST_PURCHASE
}

// ===========================================
// Analysis
// ===========================================

model Analysis {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol         String   @db.VarChar(20)
  interval       String   @default("4h") @db.VarChar(10)

  stepsCompleted Int[]    @default([]) @map("steps_completed")

  // Results stored as JSON for flexibility
  step1Result    Json?    @map("step_1_result") // Market Pulse
  step2Result    Json?    @map("step_2_result") // Asset Scanner
  step3Result    Json?    @map("step_3_result") // Safety Check
  step4Result    Json?    @map("step_4_result") // Timing
  step5Result    Json?    @map("step_5_result") // Trade Plan
  step6Result    Json?    @map("step_6_result") // Trap Check
  step7Result    Json?    @map("step_7_result") // Final Verdict

  totalScore     Decimal? @map("total_score") @db.Decimal(3, 1)
  creditsSpent   Int      @default(0) @map("credits_spent")

  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @default(dbgenerated("NOW() + INTERVAL '24 hours'")) @map("expires_at")

  @@index([userId])
  @@index([symbol])
  @@map("analyses")
}

// ===========================================
// Price Alerts
// ===========================================

model PriceAlert {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol       String   @db.VarChar(20)
  targetPrice  Decimal  @map("target_price") @db.Decimal(20, 8)
  direction    AlertDirection

  // Alert type for trade plan alerts
  alertType    AlertType @default(CUSTOM) @map("alert_type")
  reportId     String?   @map("report_id") @db.Uuid
  note         String?   @db.VarChar(255)

  // Notification channels (stored as JSON array: ["browser", "telegram", "discord", "tradingview"])
  channels     Json      @default("[\"browser\"]")

  isTriggered  Boolean  @default(false) @map("is_triggered")
  triggeredAt  DateTime? @map("triggered_at")

  creditsSpent Int      @default(1) @map("credits_spent")
  isActive     Boolean  @default(true) @map("is_active")

  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, isActive])
  @@index([symbol, isActive, isTriggered])
  @@map("price_alerts")
}

enum AlertDirection {
  ABOVE
  BELOW
}

enum AlertType {
  ENTRY
  TP1
  TP2
  TP3
  SL
  CUSTOM
}

// ===========================================
// Quizzes
// ===========================================

model Quiz {
  id           String   @id @default(uuid()) @db.Uuid
  question     String
  options      Json     // ['option1', 'option2', 'option3', 'option4']
  correctIndex Int      @map("correct_index")
  explanation  String?

  category     QuizCategory
  difficulty   Int      @default(1) // 1-3

  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  answers      QuizAnswer[]

  @@map("quizzes")
}

enum QuizCategory {
  TECHNICAL_ANALYSIS
  WHALE_BEHAVIOR
  RISK_MANAGEMENT
  MARKET_STRUCTURE
  MANIPULATION
  PSYCHOLOGY
}

model QuizAnswer {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId       String   @map("quiz_id") @db.Uuid
  quiz         Quiz     @relation(fields: [quizId], references: [id])

  answerIndex  Int      @map("answer_index")
  isCorrect    Boolean  @map("is_correct")
  creditsEarned Int     @default(0) @map("credits_earned")

  answeredAt   DateTime @default(now()) @map("answered_at")

  @@map("quiz_answers")
}

// ===========================================
// Reports
// ===========================================

model Report {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisId   String?  @map("analysis_id") @db.Uuid
  symbol       String   @db.VarChar(20)

  // Report content stored as JSON (can regenerate PDF from this)
  reportData   Json     @map("report_data")

  // AI Expert review comment
  aiExpertComment String? @map("ai_expert_comment") @db.Text

  // Verdict summary for quick display
  verdict      String   @db.VarChar(50)
  score        Decimal  @db.Decimal(3, 1)
  direction    String?  @db.VarChar(10) // 'long' or 'short'

  // Price at time of analysis (for outcome comparison)
  entryPrice   Decimal? @map("entry_price") @db.Decimal(20, 8)

  // Outcome tracking (calculated after expiration)
  outcome            String?   @db.VarChar(20) // 'correct', 'incorrect', 'neutral'
  outcomeCalculatedAt DateTime? @map("outcome_calculated_at")
  outcomePrice       Decimal?  @map("outcome_price") @db.Decimal(20, 8) // Price at expiration
  outcomePriceChange Decimal?  @map("outcome_price_change") @db.Decimal(10, 4) // Percentage change
  stepOutcomes       Json?     @map("step_outcomes") // Detailed per-step accuracy

  // Metadata
  generatedAt  DateTime @default(now()) @map("generated_at")
  expiresAt    DateTime @map("expires_at")
  downloadCount Int     @default(0) @map("download_count")

  @@index([userId])
  @@index([symbol])
  @@index([generatedAt(sort: Desc)])
  @@index([expiresAt])
  @@index([outcome])
  @@map("reports")
}

// ===========================================
// Market Data (for caching)
// ===========================================

model MarketData {
  id           String   @id @default(uuid()) @db.Uuid
  symbol       String   @db.VarChar(20)
  dataType     String   @map("data_type") @db.VarChar(50) // 'ohlcv', 'orderbook', 'trades'
  interval     String?  @db.VarChar(10)

  data         Json

  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@index([symbol, dataType])
  @@map("market_data")
}

// ===========================================
// Cost Tracking & Pricing
// ===========================================

model ApiCostLog {
  id           String   @id @default(uuid()) @db.Uuid

  // What service was used
  service      String   @db.VarChar(50) // 'gemini', 'binance', 'coingecko', 'internal'
  operation    String   @db.VarChar(100) // 'analysis_full', 'market_pulse', etc.

  // Cost details
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  costUsd      Decimal  @map("cost_usd") @db.Decimal(10, 6) // Actual cost in USD

  // Request metadata
  userId       String?  @map("user_id") @db.Uuid
  symbol       String?  @db.VarChar(20)
  metadata     Json     @default("{}")

  // Timing
  durationMs   Int      @default(0) @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([service])
  @@index([operation])
  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@map("api_cost_logs")
}

model CostSettings {
  id                    String   @id @default("default") @db.VarChar(50)

  // API Costs (per 1M tokens or per request)
  geminiInputCostPer1M  Decimal  @default(0.075) @map("gemini_input_cost_per_1m") @db.Decimal(10, 6)  // Gemini Flash input
  geminiOutputCostPer1M Decimal  @default(0.30) @map("gemini_output_cost_per_1m") @db.Decimal(10, 6)  // Gemini Flash output
  binanceCostPerRequest Decimal  @default(0) @map("binance_cost_per_request") @db.Decimal(10, 6)     // Free
  coingeckoCostPerRequest Decimal @default(0) @map("coingecko_cost_per_request") @db.Decimal(10, 6) // Free tier

  // Operational Costs (estimated per analysis)
  serverCostPerAnalysis Decimal  @default(0.001) @map("server_cost_per_analysis") @db.Decimal(10, 6)
  databaseCostPerQuery  Decimal  @default(0.00001) @map("database_cost_per_query") @db.Decimal(10, 6)

  // Pricing Configuration
  targetProfitMargin    Decimal  @default(50) @map("target_profit_margin") @db.Decimal(5, 2) // 50% profit margin
  creditPriceUsd        Decimal  @default(0.10) @map("credit_price_usd") @db.Decimal(10, 4)  // Current price per credit
  minCreditPriceUsd     Decimal  @default(0.05) @map("min_credit_price_usd") @db.Decimal(10, 4)
  maxCreditPriceUsd     Decimal  @default(0.50) @map("max_credit_price_usd") @db.Decimal(10, 4)

  // Auto-pricing settings
  autoPricingEnabled    Boolean  @default(false) @map("auto_pricing_enabled")
  autoPricingInterval   Int      @default(24) @map("auto_pricing_interval") // hours
  lastPriceUpdate       DateTime @default(now()) @map("last_price_update")

  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("cost_settings")
}
