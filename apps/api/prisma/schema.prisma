// ===========================================
// TradePath Database Schema
// ===========================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Connection pool: limit to 20 connections, 30s timeout for acquiring a connection
  // Set via DATABASE_URL query params: ?connection_limit=20&pool_timeout=30
}

// ===========================================
// User & Authentication
// ===========================================

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  emailVerified DateTime? @map("email_verified")
  passwordHash  String?  @map("password_hash") @db.VarChar(255)
  name          String?  @db.VarChar(100)
  image         String?  @map("avatar_url")
  isAdmin       Boolean  @default(false) @map("is_admin")
  googleId      String?  @unique @map("google_id") @db.VarChar(255)

  // ===========================================
  // Email Verification
  // ===========================================
  emailVerificationToken   String?   @unique @map("email_verification_token") @db.VarChar(255)
  emailVerificationExpires DateTime? @map("email_verification_expires")

  // ===========================================
  // Password Reset
  // ===========================================
  passwordResetToken   String?   @unique @map("password_reset_token") @db.VarChar(255)
  passwordResetExpires DateTime? @map("password_reset_expires")

  // ===========================================
  // Two-Factor Authentication (2FA)
  // ===========================================
  twoFactorEnabled     Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret      String?   @map("two_factor_secret") @db.VarChar(255)
  twoFactorBackupCodes String[]  @default([]) @map("two_factor_backup_codes")

  // ===========================================
  // Account Security & Lockout
  // ===========================================
  accountLocked       Boolean   @default(false) @map("account_locked")
  accountLockedUntil  DateTime? @map("account_locked_until")
  loginAttempts       Int       @default(0) @map("login_attempts")
  lastLoginIp         String?   @map("last_login_ip") @db.VarChar(45)
  lastLoginDevice     String?   @map("last_login_device") @db.VarChar(500)
  lastLoginLocation   String?   @map("last_login_location") @db.VarChar(255)

  // ===========================================
  // First Login & Registration Tracking
  // ===========================================
  registrationEmail       String?   @map("registration_email") @db.VarChar(255)  // Original email used at registration
  firstLoginBonusReceived Boolean   @default(false) @map("first_login_bonus_received")  // Track if first login bonus was given

  // Gamification
  level         Int      @default(1)
  xp            Int      @default(0)
  streakDays    Int      @default(0) @map("streak_days")
  streakLastDate DateTime? @map("streak_last_date") @db.Date

  // Settings
  preferredCoins String[] @default(["BTC", "ETH", "SOL"]) @map("preferred_coins")
  notificationSettings Json @default("{}") @map("notification_settings")
  reportValidityPeriods Int @default(50) @map("report_validity_periods") // Number of periods before report expires
  preferredInterface String? @map("preferred_interface") @db.VarChar(20) // 'ui' | 'concierge' | null (not selected)
  preferredLanguage String @default("en") @map("preferred_language") @db.VarChar(10) // Language code: en, tr, ar, es, de, fr, etc.

  // Social Notification Settings
  telegramChatId   String?  @map("telegram_chat_id") @db.VarChar(50)
  discordWebhookUrl String? @map("discord_webhook_url") @db.VarChar(500)
  twitterHandle    String?  @map("twitter_handle") @db.VarChar(50)

  // Referral
  referralCode  String?  @unique @map("referral_code") @db.VarChar(20)
  referredById  String?  @map("referred_by_id") @db.Uuid
  referredBy    User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("UserReferrals")

  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  // Auth.js Relations
  accounts      Account[]
  sessions      Session[]

  // Security Relations
  loginAuditLogs LoginAuditLog[]

  // App Relations
  creditBalance    CreditBalance?
  creditTransactions CreditTransaction[]
  analyses         Analysis[]
  priceAlerts      PriceAlert[]
  dailyRewards     DailyReward[]
  achievements     UserAchievement[]
  referralsMade    Referral[] @relation("ReferrerReferrals")
  referralReceived Referral?  @relation("ReferredReferrals")
  quizAnswers      QuizAnswer[]
  reports          Report[]
  scheduledReports ScheduledReport[]
  dailyPasses      DailyPass[]
  signalPreferences UserSignalPreferences?
  signalSubscription SignalSubscription?
  subscription     Subscription?
  notifications    Notification[]

  @@map("users")
}

// ===========================================
// Auth.js Tables
// ===========================================

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===========================================
// Security & Audit Logging
// ===========================================

model LoginAuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  email        String   @db.VarChar(255) // Store email even if user is deleted
  eventType    LoginEventType @map("event_type")

  // Request details
  ipAddress    String   @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  location     String?  @db.VarChar(255) // "City, Country" from IP geolocation

  // Additional context
  success      Boolean  @default(false)
  failureReason String? @map("failure_reason") @db.VarChar(255)
  metadata     Json     @default("{}")

  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([email])
  @@index([ipAddress])
  @@index([eventType])
  @@index([createdAt(sort: Desc)])
  @@map("login_audit_logs")
}

enum LoginEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_BLOCKED
  LOGOUT
  PASSWORD_CHANGE
  PASSWORD_RESET
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_SUCCESS
  EMAIL_VERIFICATION_SENT
  EMAIL_VERIFIED
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  TWO_FACTOR_SUCCESS
  TWO_FACTOR_FAILED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  SUSPICIOUS_ACTIVITY
  SUSPICIOUS_LOGIN
  NEW_DEVICE_LOGIN
}

model TokenBlacklist {
  id           String   @id @default(uuid()) @db.Uuid
  token        String   @unique @db.VarChar(500) // JWT token hash
  userId       String   @map("user_id") @db.Uuid
  reason       String   @db.VarChar(100) // 'logout', 'password_change', 'security', 'admin'
  expiresAt    DateTime @map("expires_at") // When the original token would have expired

  createdAt    DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("token_blacklist")
}

// ===========================================
// Credits System
// ===========================================

model CreditBalance {
  userId           String   @id @map("user_id") @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance          Int      @default(25)

  lifetimeEarned   Int      @default(25) @map("lifetime_earned")
  lifetimeSpent    Int      @default(0) @map("lifetime_spent")
  lifetimePurchased Int     @default(0) @map("lifetime_purchased")

  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("credit_balances")
}

model CreditTransaction {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount       Int      // positive = credit, negative = debit
  balanceAfter Int      @map("balance_after")

  type         TransactionType
  source       String   @db.VarChar(100) // 'daily_login', 'spin', 'quiz', 'analysis_step_2', etc.

  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("credits_ledger")
}

enum TransactionType {
  PURCHASE
  REWARD
  SPEND
  REFUND
  REFERRAL
  BONUS
  ADJUSTMENT
}

model CreditPackage {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @unique @db.VarChar(50)
  credits         Int
  bonusCredits    Int      @default(0) @map("bonus_credits")
  priceUsd        Decimal  @map("price_usd") @db.Decimal(10, 2)
  pricePerCredit  Decimal  @map("price_per_credit") @db.Decimal(10, 4)
  discountPercent Int      @default(0) @map("discount_percent")
  isPopular       Boolean  @default(false) @map("is_popular")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("credit_packages")
}

// ===========================================
// Achievements & Rewards
// ===========================================

model Achievement {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @unique @db.VarChar(50)
  name            String   @db.VarChar(100)
  description     String?
  category        AchievementCategory
  icon            String?  @db.VarChar(50)

  xpReward        Int      @default(0) @map("xp_reward")
  creditReward    Int      @default(0) @map("credit_reward")

  requirementType RequirementType @map("requirement_type")
  requirementValue Int     @map("requirement_value")
  requirementMetadata Json @default("{}") @map("requirement_metadata")

  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  users           UserAchievement[]

  @@map("achievements")
}

enum AchievementCategory {
  ANALYSIS
  WHALE
  TRADING
  SOCIAL
  EDUCATION
  STREAK
}

enum RequirementType {
  COUNT
  STREAK
  PERCENTAGE
  SINGLE
}

model UserAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String   @map("achievement_id") @db.Uuid
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  progress      Int      @default(0)
  isUnlocked    Boolean  @default(false) @map("is_unlocked")
  unlockedAt    DateTime? @map("unlocked_at")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model DailyReward {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardDate   DateTime @map("reward_date") @db.Date

  loginClaimed Boolean  @default(false) @map("login_claimed")
  loginCredits Int      @default(0) @map("login_credits")

  spinUsed     Boolean  @default(false) @map("spin_used")
  spinResult   Int      @default(0) @map("spin_result")

  quizCompleted Boolean @default(false) @map("quiz_completed")
  quizCorrect  Boolean  @default(false) @map("quiz_correct")
  quizCredits  Int      @default(0) @map("quiz_credits")

  adsWatched   Int      @default(0) @map("ads_watched")
  adsCredits   Int      @default(0) @map("ads_credits")

  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([userId, rewardDate])
  @@index([userId, rewardDate])
  @@map("daily_rewards")
}

// ===========================================
// Referrals
// ===========================================

model Referral {
  id              String   @id @default(uuid()) @db.Uuid
  referrerId      String   @map("referrer_id") @db.Uuid
  referrer        User     @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredId      String   @unique @map("referred_id") @db.Uuid
  referred        User     @relation("ReferredReferrals", fields: [referredId], references: [id])

  status          ReferralStatus @default(PENDING)

  referrerCreditsEarned Int @default(0) @map("referrer_credits_earned")
  referredCreditsEarned Int @default(0) @map("referred_credits_earned")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([referrerId])
  @@map("referrals")
}

enum ReferralStatus {
  PENDING
  REGISTERED
  FIRST_ANALYSIS
  FIRST_PURCHASE
}

// ===========================================
// Analysis
// ===========================================

model Analysis {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol         String   @db.VarChar(20)
  interval       String   @default("4h") @db.VarChar(10)
  method         String   @default("classic") @db.VarChar(20) // 'classic' or 'mlis_pro'

  stepsCompleted Int[]    @default([]) @map("steps_completed")

  // Results stored as JSON for flexibility
  step1Result    Json?    @map("step_1_result") // Market Pulse
  step2Result    Json?    @map("step_2_result") // Asset Scanner
  step3Result    Json?    @map("step_3_result") // Safety Check
  step4Result    Json?    @map("step_4_result") // Timing
  step5Result    Json?    @map("step_5_result") // Trade Plan
  step6Result    Json?    @map("step_6_result") // Trap Check
  step7Result    Json?    @map("step_7_result") // Final Verdict

  totalScore     Decimal? @map("total_score") @db.Decimal(3, 1)
  creditsSpent   Int      @default(0) @map("credits_spent")

  // AI Expert question tracking (3 free per analysis, then 5 credits each)
  aiExpertQuestionsUsed Int @default(0) @map("ai_expert_questions_used")

  // Download/Email tracking (2 free each per analysis)
  pdfDownloadsUsed Int @default(0) @map("pdf_downloads_used")
  emailsSentUsed   Int @default(0) @map("emails_sent_used")

  // Outcome tracking for TP/SL hit detection
  outcome            String?   @db.VarChar(20) // 'tp1_hit', 'tp2_hit', 'tp3_hit', 'sl_hit', 'pending'
  outcomePrice       Decimal?  @map("outcome_price") @db.Decimal(20, 8) // Price when TP/SL was hit
  outcomeAt          DateTime? @map("outcome_at") // When outcome was determined

  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @default(dbgenerated("NOW() + INTERVAL '24 hours'")) @map("expires_at")

  @@index([userId])
  @@index([symbol])
  @@index([outcome])
  @@map("analyses")
}

// ===========================================
// Price Alerts
// ===========================================

model PriceAlert {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol       String   @db.VarChar(20)
  targetPrice  Decimal  @map("target_price") @db.Decimal(20, 8)
  direction    AlertDirection

  // Alert type for trade plan alerts
  alertType    AlertType @default(CUSTOM) @map("alert_type")
  reportId     String?   @map("report_id") @db.Uuid
  note         String?   @db.VarChar(255)

  // Notification channels (stored as JSON array: ["browser", "telegram", "discord", "tradingview"])
  channels     Json      @default("[\"browser\"]")

  isTriggered  Boolean  @default(false) @map("is_triggered")
  triggeredAt  DateTime? @map("triggered_at")

  creditsSpent Int      @default(1) @map("credits_spent")
  isActive     Boolean  @default(true) @map("is_active")

  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, isActive])
  @@index([symbol, isActive, isTriggered])
  @@map("price_alerts")
}

enum AlertDirection {
  ABOVE
  BELOW
}

enum AlertType {
  ENTRY
  TP1
  TP2
  TP3
  SL
  CUSTOM
}

// ===========================================
// Scheduled Reports
// ===========================================

model ScheduledReport {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  symbol       String   @db.VarChar(20)
  interval     String   @default("4h") @db.VarChar(10) // e.g., '15m', '1h', '4h', '1d'
  frequency    ScheduleFrequency  @default(DAILY)

  // Delivery options
  deliverEmail    Boolean @default(true) @map("deliver_email")
  deliverTelegram Boolean @default(false) @map("deliver_telegram")
  deliverDiscord  Boolean @default(false) @map("deliver_discord")

  // Schedule timing (hour in UTC, 0-23)
  scheduleHour Int      @default(8) @map("schedule_hour")

  // For weekly schedules (0=Sunday, 1=Monday, etc.)
  scheduleDayOfWeek Int? @map("schedule_day_of_week")

  // Last execution tracking
  lastRunAt    DateTime? @map("last_run_at")
  nextRunAt    DateTime  @map("next_run_at")

  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, isActive])
  @@index([nextRunAt, isActive])
  @@map("scheduled_reports")
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ===========================================
// Quizzes
// ===========================================

model Quiz {
  id           String   @id @default(uuid()) @db.Uuid
  question     String
  options      Json     // ['option1', 'option2', 'option3', 'option4']
  correctIndex Int      @map("correct_index")
  explanation  String?

  category     QuizCategory
  difficulty   Int      @default(1) // 1-3

  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  answers      QuizAnswer[]

  @@map("quizzes")
}

enum QuizCategory {
  TECHNICAL_ANALYSIS
  WHALE_BEHAVIOR
  RISK_MANAGEMENT
  MARKET_STRUCTURE
  MANIPULATION
  PSYCHOLOGY
}

model QuizAnswer {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId       String   @map("quiz_id") @db.Uuid
  quiz         Quiz     @relation(fields: [quizId], references: [id])

  answerIndex  Int      @map("answer_index")
  isCorrect    Boolean  @map("is_correct")
  creditsEarned Int     @default(0) @map("credits_earned")

  answeredAt   DateTime @default(now()) @map("answered_at")

  @@map("quiz_answers")
}

// ===========================================
// Reports
// ===========================================

model Report {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisId   String?  @map("analysis_id") @db.Uuid
  symbol       String   @db.VarChar(20)

  // Report content stored as JSON (can regenerate PDF from this)
  reportData   Json     @map("report_data")

  // AI Expert review comment
  aiExpertComment String? @map("ai_expert_comment") @db.Text

  // Verdict summary for quick display
  verdict      String   @db.VarChar(50)
  score        Decimal  @db.Decimal(3, 1)
  direction    String?  @db.VarChar(10) // 'long' or 'short'
  tradeType    String?  @map("trade_type") @db.VarChar(20) // 'scalping', 'dayTrade', 'swing'

  // Price at time of analysis (for outcome comparison)
  entryPrice   Decimal? @map("entry_price") @db.Decimal(20, 8)

  // Outcome tracking (calculated after expiration)
  outcome            String?   @db.VarChar(20) // 'correct', 'incorrect', 'neutral'
  outcomeCalculatedAt DateTime? @map("outcome_calculated_at")
  outcomePrice       Decimal?  @map("outcome_price") @db.Decimal(20, 8) // Price at expiration
  outcomePriceChange Decimal?  @map("outcome_price_change") @db.Decimal(10, 4) // Percentage change
  stepOutcomes       Json?     @map("step_outcomes") // Detailed per-step accuracy

  // Metadata
  generatedAt  DateTime @default(now()) @map("generated_at")
  expiresAt    DateTime @map("expires_at")
  downloadCount Int     @default(0) @map("download_count")
  isPublic     Boolean  @default(false) @map("is_public") // Admin reports visible to all users

  @@index([userId])
  @@index([symbol])
  @@index([generatedAt(sort: Desc)])
  @@index([expiresAt])
  @@index([outcome])
  @@index([isPublic])
  @@index([tradeType])
  @@map("reports")
}

// ===========================================
// Market Data (for caching)
// ===========================================

model MarketData {
  id           String   @id @default(uuid()) @db.Uuid
  symbol       String   @db.VarChar(20)
  dataType     String   @map("data_type") @db.VarChar(50) // 'ohlcv', 'orderbook', 'trades'
  interval     String?  @db.VarChar(10)

  data         Json

  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@index([symbol, dataType])
  @@map("market_data")
}

// ===========================================
// Cost Tracking & Pricing
// ===========================================

model ApiCostLog {
  id           String   @id @default(uuid()) @db.Uuid

  // What service was used
  service      String   @db.VarChar(50) // 'gemini', 'binance', 'coingecko', 'internal'
  operation    String   @db.VarChar(100) // 'analysis_full', 'market_pulse', etc.

  // Cost details
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  costUsd      Decimal  @map("cost_usd") @db.Decimal(10, 6) // Actual cost in USD

  // Request metadata
  userId       String?  @map("user_id") @db.Uuid
  symbol       String?  @db.VarChar(20)
  metadata     Json     @default("{}")

  // Timing
  durationMs   Int      @default(0) @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([service])
  @@index([operation])
  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@map("api_cost_logs")
}

model CostSettings {
  id                    String   @id @default("default") @db.VarChar(50)

  // API Costs (per 1M tokens or per request)
  geminiInputCostPer1M  Decimal  @default(0.075) @map("gemini_input_cost_per_1m") @db.Decimal(10, 6)  // Gemini Flash input
  geminiOutputCostPer1M Decimal  @default(0.30) @map("gemini_output_cost_per_1m") @db.Decimal(10, 6)  // Gemini Flash output
  binanceCostPerRequest Decimal  @default(0) @map("binance_cost_per_request") @db.Decimal(10, 6)     // Free
  coingeckoCostPerRequest Decimal @default(0) @map("coingecko_cost_per_request") @db.Decimal(10, 6) // Free tier

  // Operational Costs (estimated per analysis)
  serverCostPerAnalysis Decimal  @default(0.001) @map("server_cost_per_analysis") @db.Decimal(10, 6)
  databaseCostPerQuery  Decimal  @default(0.00001) @map("database_cost_per_query") @db.Decimal(10, 6)

  // Pricing Configuration
  targetProfitMargin    Decimal  @default(50) @map("target_profit_margin") @db.Decimal(5, 2) // 50% profit margin
