// ===========================================
// Coin Score Cache (Top Coins by Reliability)
// ===========================================

model CoinScoreCache {
  id           String   @id @default(uuid()) @db.Uuid
  symbol       String   @unique @db.VarChar(20)

  // Analysis scores
  totalScore       Decimal  @map("total_score") @db.Decimal(4, 1)      // 0-100 overall score
  reliabilityScore Decimal  @map("reliability_score") @db.Decimal(4, 1) // 0-100 reliability score

  // Score components
  liquidityScore   Decimal  @map("liquidity_score") @db.Decimal(4, 1)   // Volume/MarketCap ratio
  volatilityScore  Decimal  @map("volatility_score") @db.Decimal(4, 1)  // ATR-based (lower = more stable)
  trendScore       Decimal  @map("trend_score") @db.Decimal(4, 1)       // MA convergence
  momentumScore    Decimal  @map("momentum_score") @db.Decimal(4, 1)    // RSI, MACD strength

  // Verdict info
  verdict          String   @db.VarChar(20) // GO, CONDITIONAL_GO, WAIT, AVOID
  direction        String?  @db.VarChar(10) // LONG, SHORT
  confidence       Decimal  @db.Decimal(3, 1) // 0-10 confidence level

  // Market data snapshot
  price            Decimal  @db.Decimal(20, 8)
  priceChange24h   Decimal  @map("price_change_24h") @db.Decimal(6, 2)
  volume24h        Decimal  @map("volume_24h") @db.Decimal(20, 2)
  marketCap        Decimal  @map("market_cap") @db.Decimal(20, 2)

  // Analysis reference
  analysisId       String?  @map("analysis_id") @db.Uuid
  interval         String   @default("4h") @db.VarChar(10)

  // Timestamps
  scannedAt        DateTime @default(now()) @map("scanned_at")
  expiresAt        DateTime @map("expires_at")

  @@index([reliabilityScore(sort: Desc)])
  @@index([totalScore(sort: Desc)])
  @@index([verdict])
  @@index([scannedAt])
  @@map("coin_score_cache")
}

// ===========================================
// Multi-Asset Score Cache (Stocks, Bonds, Metals)
// Same structure as CoinScoreCache but for traditional markets
// ===========================================

model AssetScoreCache {
  id           String   @id @default(uuid()) @db.Uuid
  symbol       String   @db.VarChar(20)
  market       String   @db.VarChar(20) // stocks, bonds, metals
  name         String   @db.VarChar(100) // Company/ETF name

  // Analysis scores
  totalScore       Decimal  @map("total_score") @db.Decimal(4, 1)
  reliabilityScore Decimal  @map("reliability_score") @db.Decimal(4, 1)

  // Score components
  trendScore       Decimal  @map("trend_score") @db.Decimal(4, 1)
  momentumScore    Decimal  @map("momentum_score") @db.Decimal(4, 1)
  volatilityScore  Decimal  @map("volatility_score") @db.Decimal(4, 1)
  volumeScore      Decimal  @map("volume_score") @db.Decimal(4, 1)

  // Verdict info
  verdict          String   @db.VarChar(20) // GO, CONDITIONAL_GO, WAIT, AVOID
  direction        String?  @db.VarChar(10) // LONG, SHORT
  confidence       Decimal  @db.Decimal(3, 1)

  // Market data snapshot
  price            Decimal  @db.Decimal(20, 8)
  priceChange1d    Decimal  @map("price_change_1d") @db.Decimal(6, 2)
  priceChange5d    Decimal  @map("price_change_5d") @db.Decimal(6, 2)
  priceChange1m    Decimal  @map("price_change_1m") @db.Decimal(6, 2)
  volume           Decimal  @db.Decimal(20, 2)
  avgVolume        Decimal  @map("avg_volume") @db.Decimal(20, 2)
  fiftyDayAvg      Decimal  @map("fifty_day_avg") @db.Decimal(20, 8)
  twoHundredDayAvg Decimal  @map("two_hundred_day_avg") @db.Decimal(20, 8)

  // Analysis reference
  analysisId       String?  @map("analysis_id") @db.Uuid

  // Timestamps
  scannedAt        DateTime @default(now()) @map("scanned_at")
  expiresAt        DateTime @map("expires_at")

  @@unique([symbol, market], name: "symbol_market")
  @@index([market])
  @@index([reliabilityScore(sort: Desc)])
  @@index([totalScore(sort: Desc)])
  @@index([verdict])
  @@index([scannedAt])
  @@map("asset_score_cache")
}

// ===========================================
// TFT Prediction Models
// ===========================================

model TFTModel {
  id           String   @id @default(uuid()) @db.Uuid

  // Model identification
  name         String   @db.VarChar(100) // e.g., "TFT Swing v1.2.0"
  version      String   @db.VarChar(20)  // e.g., "1.2.0"
  tradeType    String   @map("trade_type") @db.VarChar(20) // scalp, swing, position

  // Model file path (relative or cloud storage URL)
  filePath     String   @map("file_path") @db.VarChar(500)
  fileSize     BigInt   @map("file_size") // bytes
  checksum     String?  @db.VarChar(64) // SHA256 for integrity check

  // Training configuration
  symbols      String[] // ["BTC", "ETH", "SOL"]
  epochs       Int
  batchSize    Int      @default(64) @map("batch_size")
  dataInterval String   @map("data_interval") @db.VarChar(10) // 15m, 1h, 4h
  lookbackDays Int      @map("lookback_days")

  // Training metrics
  validationLoss  Decimal  @map("validation_loss") @db.Decimal(10, 6)
  mape            Decimal  @db.Decimal(6, 2) // Mean Absolute Percentage Error
  trainingSamples Int      @map("training_samples")
  trainingTime    Int      @map("training_time") // seconds

  // Hyperparameters (stored as JSON)
  hyperparameters Json     @default("{}") // hidden_size, attention_heads, dropout, etc.

  // Status
  status       TFTModelStatus @default(READY)
  isActive     Boolean  @default(false) @map("is_active") // Only one can be active per tradeType

  // Metadata
  description  String?  @db.VarChar(500)
  trainedBy    String?  @map("trained_by") @db.Uuid // Admin user ID

  // Timestamps
  createdAt    DateTime @default(now()) @map("created_at")
  activatedAt  DateTime? @map("activated_at")

  @@index([tradeType, isActive])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("tft_models")
}

enum TFTModelStatus {
  TRAINING
  READY
  ACTIVE
  ARCHIVED
  FAILED
}

// ===========================================
// Daily Pass System
// Tracks daily passes for Capital Flow and Asset Analysis
// ===========================================

model DailyPass {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  passType     DailyPassType @map("pass_type")
  passDate     DateTime @map("pass_date") @db.Date // The date this pass is valid for
  creditsCost  Int      @map("credits_cost") // How many credits were charged

  // Usage tracking (for asset_analysis pass)
  usageCount   Int      @default(0) @map("usage_count") // Number of analyses done today
  maxUsage     Int      @default(10) @map("max_usage") // Maximum allowed (10 for asset analysis)

  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at") // End of day UTC

  @@unique([userId, passType, passDate], name: "unique_daily_pass")
  @@index([userId])
  @@index([passType])
  @@index([passDate])
  @@index([expiresAt])
  @@map("daily_passes")
}

enum DailyPassType {
  CAPITAL_FLOW_L3    // 25 credits/day - Sector Activity (Layer 3)
  CAPITAL_FLOW_L4    // 25 credits/day - AI Recommendations (Layer 4)
  ASSET_ANALYSIS     // 100 credits/day - Asset Analysis (max 10)
}

// ===========================================
// Subscriptions
// Stripe-based subscription management for tiered access
// ===========================================

model Subscription {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stripe identifiers
  stripeCustomerId     String?  @unique @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id") @db.VarChar(255)
  stripePriceId        String?  @map("stripe_price_id") @db.VarChar(255)

  // Subscription tier
  tier         SubscriptionTier @default(FREE)
  status       SubscriptionStatus @default(INACTIVE)

  // Billing period
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")

  // Timestamps
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([tier])
  @@index([status])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  ELITE
}

enum SubscriptionStatus {
  INACTIVE        // No active subscription
  ACTIVE          // Subscription is active
  PAST_DUE        // Payment failed, grace period
  CANCELED        // Canceled but period not ended
  UNPAID          // Payment failed, access revoked
  TRIALING        // On trial period
}

// ===========================================
// Asset Logos Cache
