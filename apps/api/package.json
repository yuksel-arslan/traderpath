{
  "name": "@tradepath/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma generate && prisma db push --skip-generate --accept-data-loss && tsx watch src/index.ts",
    "dev:quick": "tsx watch src/index.ts",
    "build": "cross-env PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma generate && tsup",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "clean": "rimraf dist node_modules",
    "postinstall": "prisma generate || echo 'Prisma generate skipped'",
    "db:generate": "cross-env PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^8.4.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/rate-limit": "^9.0.1",
    "@fastify/websocket": "^8.3.1",
    "@prisma/client": "^6.2.1",
    "@tradepath/analysis-engine": "workspace:*",
    "@tradepath/types": "workspace:*",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.2",
    "bullmq": "^4.15.1",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.24.3",
    "fastify-raw-body": "4.3.0",
    "google-auth-library": "^9.14.0",
    "ioredis": "^5.3.2",
    "jose": "^6.1.3",
    "nanoid": "^5.0.4",
    "pg": "^8.16.3",
    "pino": "^8.16.2",
    "pino-pretty": "^10.3.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.2",
    "speakeasy": "^2.0.0",
    "stripe": "^14.8.0",
    "web-push": "^3.6.7",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "tsup": "^8.0.1",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.10",
    "cross-env": "^7.0.3",
    "eslint": "^8.55.0",
    "prisma": "^6.2.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.0",
    "vitest": "^1.0.4"
  }
}
