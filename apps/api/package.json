{
  "name": "@tradepath/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate && prisma db push --skip-generate && tsx watch src/index.ts",
    "dev:quick": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "clean": "rm -rf dist node_modules",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^8.4.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/rate-limit": "^9.0.1",
    "@fastify/websocket": "^8.3.1",
    "@prisma/client": "^5.7.0",
    "@tradepath/analysis-engine": "workspace:*",
    "@tradepath/types": "workspace:*",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "bullmq": "^4.15.1",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.24.3",
    "ioredis": "^5.3.2",
    "nanoid": "^5.0.4",
    "pino": "^8.16.2",
    "pino-pretty": "^10.3.0",
    "socket.io": "^4.7.2",
    "stripe": "^14.8.0",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "eslint": "^8.55.0",
    "prisma": "^5.7.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.0",
    "vitest": "^1.0.4"
  }
}
