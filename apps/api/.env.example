# ===========================================
# TraderPath API - Environment Variables
# ===========================================

# App Configuration
NODE_ENV=production
PORT=4000
APP_URL=https://your-frontend-domain.vercel.app
API_URL=https://your-api-domain.railway.app

# CORS (comma-separated origins, optional - defaults to APP_URL)
# CORS_ORIGINS=https://domain1.com,https://domain2.com

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Redis (Railway provides this automatically)
REDIS_URL=redis://default:password@host:6379

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-minimum-32-chars
REFRESH_TOKEN_EXPIRES_IN=30d

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Stripe (for recurring subscriptions: Starter/Pro/Elite tiers)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Lemon Squeezy (for one-time credit package purchases)
# LEMON_SQUEEZY_API_KEY=
# LEMON_SQUEEZY_STORE_ID=
# LEMON_SQUEEZY_WEBHOOK_SECRET=
# LEMON_SQUEEZY_DEFAULT_VARIANT_ID=  # fallback variant used for dynamic-price checkouts

# Binance (optional)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# FRED - Federal Reserve Economic Data (REQUIRED for Capital Flow Pipeline)
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# Without this, the Flow → Action Pipeline shows static fallback data
FRED_API_KEY=your_fred_api_key

# AI Services (at least one recommended)
OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# External API Isolation (default: false)
# Set to 'true' to disable ALL external API calls (FRED, Yahoo, Binance, DefiLlama)
# WARNING: This makes the Flow → Action Pipeline return static fallback data!
# Only use for local development or when external APIs are unavailable
# DISABLE_EXTERNAL_APIS=true
