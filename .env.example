# ===========================================
# TradePath Environment Variables
# ===========================================

# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database (Neon)
DATABASE_URL=postgresql://user:password@host.neon.tech/tradepath?sslmode=require

# Redis (Upstash)
REDIS_URL=redis://default:password@host.upstash.io:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Binance API
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# AI APIs
OPENAI_API_KEY=sk-xxx
GEMINI_API_KEY=xxx

# External APIs
COINGECKO_API_KEY=xxx
FEAR_GREED_API_KEY=xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
FROM_EMAIL=noreply@tradepath.io

# Push Notifications
VAPID_PUBLIC_KEY=xxx
VAPID_PRIVATE_KEY=xxx

# Encryption
ENCRYPTION_KEY=64-char-hex-string
ENCRYPTION_IV=32-char-hex-string

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Feature Flags
ENABLE_ADS=true
ENABLE_CRYPTO_PAYMENTS=false
MAINTENANCE_MODE=false
