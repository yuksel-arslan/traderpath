# ===========================================
# TradePath Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# For production, use production-grade secrets!
# ===========================================

# App
NODE_ENV=development  # development | production
APP_URL=http://localhost:3000  # Production: https://tradepath.io
API_URL=http://localhost:4000  # Production: https://api.tradepath.io

# Database
# Local Docker (default):
DATABASE_URL=postgresql://tradepath:tradepath123@localhost:5432/tradepath
DIRECT_URL=postgresql://tradepath:tradepath123@localhost:5432/tradepath

# Neon (production) - Use pooled connection for DATABASE_URL:
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/tradepath?sslmode=require
# DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/tradepath?sslmode=require
# Note: DATABASE_URL should use the pooler endpoint (-pooler), DIRECT_URL should use direct endpoint

# Redis
# Local Docker (default):
REDIS_URL=redis://localhost:6379
# Or Upstash (production):
# REDIS_URL=redis://default:password@host.upstash.io:6379

# Docker Compose Settings (optional, defaults shown)
DB_USER=tradepath
DB_PASSWORD=tradepath123
DB_NAME=tradepath
DB_PORT=5432
REDIS_PORT=6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe
# Get keys from https://dashboard.stripe.com/apikeys
# Production: Use sk_live_xxx, pk_live_xxx keys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx  # Create webhook at https://dashboard.stripe.com/webhooks
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Binance API
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# AI APIs
OPENAI_API_KEY=sk-xxx
GEMINI_API_KEY=xxx

# External APIs
COINGECKO_API_KEY=xxx
FEAR_GREED_API_KEY=xxx
NEWS_API_KEY=xxx
NEWS_API_URL=https://cryptopanic.com/api/v1

# Email (Resend)
RESEND_API_KEY=re_xxx
FROM_EMAIL=noreply@tradepath.io

# Push Notifications
VAPID_PUBLIC_KEY=xxx
VAPID_PRIVATE_KEY=xxx

# Encryption
ENCRYPTION_KEY=64-char-hex-string
ENCRYPTION_IV=32-char-hex-string

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Feature Flags
ENABLE_ADS=true
ENABLE_CRYPTO_PAYMENTS=false
MAINTENANCE_MODE=false
